{
  "type": "module",
  "scripts": {
    "build": "rimraf dist && webpack --config webpack.production.js",
    "dev": "tsx watch --env-file=.env.development  src/index.ts",
    "prod": "node -r tsconfig-paths/register dist/index.cjs",
    "lint": "eslint . --cache --format  stylish --fix",
    "format": "npx prettier . --write",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts, *.js": [
      "npm run lint && npm run format"
    ]
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "concurrently": "^9.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^7.4.4",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "rimraf": "^6.0.1",
    "sequelize": "^6.37.5",
    "tsconfig-paths": "^4.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/sequelize": "^4.28.20",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin": "^1.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prefer-arrow-functions": "^3.4.1",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "import": "^0.0.6",
    "lint-staged": "^15.2.11",
    "path": "^0.12.7",
    "prettier": "^3.3.3",
    "ts-loader": "^9.5.1",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.13.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "webpack-node-externals": "^3.0.0"
  }
}
